{
	"name": "money-tycoon-profit-tap",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "oxlint",
		"preview": "npm run build && vite preview",
		"db:generate": "drizzle-kit generate",
		"db:migrate:remote": "wrangler d1 migrations apply moneytycoon --remote",
		"deploy": "npm run db:generate && npm run db:migrate:remote && wrangler types && npm run build && wrangler deploy",
		"deploy": "wrangler types && npm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@hono/zod-validator": "^0.8.0",
		"@tailwindcss/vite": "^4.3.2",
		"@telegram-apps/navigation": "^1.0.14",
		"@telegram-apps/sdk": "^3.11.8",
		"@telegram-apps/sdk-react": "^3.3.9",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^1.0.0-rc.4",
		"hono": "^4.12.27",
		"lucide-react": "^1.23.0",
		"motion": "^12.42.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"shadcn": "^4.13.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.43.0",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"drizzle-kit": "^1.0.0-rc.4",
		"oxlint": "^1.69.0",
		"telegram-webapps": "^9.6.0",
		"typescript": "~6.0.2",
		"vite": "^8.1.0",
		"wrangler": "^4.107.0"
	}
}
